# Copia este archivo como .env en la raiz si necesitas cambiar los valores.
DB_NAME=AgroDB
DB_USERNAME=agro_user
BD_PASSWORD=agro_password
BACKEND_PORT=3000
FRONTEND_PORT=5173
BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:3000

# Cambia estos secretos antes de usar la aplicacion fuera de desarrollo local.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_REFRESH_EXPIRES_IN=7d

PAYMENT_PLATFORM_COMMISSION_PERCENTAGE=10
ACCOUNT_CANCELLATION_JOB_ENABLED=false
ACCOUNT_CANCELLATION_JOB_INTERVAL_MS=3600000
